<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <AssemblyName>Jellyfin.Plugin.Ratings</AssemblyName>
    <RootNamespace>Jellyfin.Plugin.Ratings</RootNamespace>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <Nullable>enable</Nullable>
    <AnalysisMode>AllEnabledByDefault</AnalysisMode>
    <Version>1.0.355.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Jellyfin.Controller" Version="10.11.0" />
    <PackageReference Include="Jellyfin.Model" Version="10.11.0" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration\*.html" />
    <!-- ratings.js is embedded as a MINIFIED copy (see the statically-declared resource and
         MinifyRatingsJs target below), so exclude the raw source here to avoid a duplicate name. -->
    <EmbeddedResource Include="Web\**\*.*" Exclude="Web\ratings.js" />
    <EmbeddedResource Include="Pages\*" />
    <!-- Minified ratings.js, generated by MinifyRatingsJs before CoreCompile. A literal path is
         included as an item from evaluation time even though the file is produced during the build,
         so the compiler embeds it under the SAME resource name the controller serves. -->
    <EmbeddedResource Include="$(IntermediateOutputPath)ratings.min.js" LogicalName="Jellyfin.Plugin.Ratings.Web.ratings.js" />
  </ItemGroup>

  <!-- Build-time minification of the injected web bundle.
       The source Web/ratings.js stays readable/editable; the build embeds a minified copy.
       esbuild only compacts whitespace and LOCAL variable names - it never renames object or
       API property names - so runtime behavior is preserved. If esbuild/node is unavailable,
       the build falls back to copying the unminified file so it can never break the build. -->
  <Target Name="MinifyRatingsJs" BeforeTargets="CoreCompile" Inputs="Web/ratings.js" Outputs="$(IntermediateOutputPath)ratings.min.js">
    <Exec Command="npx --yes esbuild@0.28.0 &quot;Web/ratings.js&quot; --minify --charset=utf8 --legal-comments=none --log-level=error --outfile=&quot;$(IntermediateOutputPath)ratings.min.js&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)"
          ContinueOnError="true" />
    <Warning Condition="!Exists('$(IntermediateOutputPath)ratings.min.js')" Text="esbuild minify unavailable - embedding unminified ratings.js" />
    <Copy Condition="!Exists('$(IntermediateOutputPath)ratings.min.js')" SourceFiles="Web/ratings.js" DestinationFiles="$(IntermediateOutputPath)ratings.min.js" />
  </Target>

</Project>
